.venv/
venv/
ENV/
env/
lib/
bin/

# === 파이썬 캐시 및 빌드 결과물 ===
# 모든 하위 디렉토리의 __pycache__ 폴더와 .pyc 파일 제외
**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# === 설정 및 비밀 키 (Security) ===
# 보안을 위해 API 키가 포함된 설정 파일은 반드시 제외
.env
agent_memory.json
# config.py 내부에 API 키가 있다면 제외 (필요 시 config.example.py 등으로 템플릿만 공유)
demo/ai_assistant/config.py

# === IDE 및 시스템 설정 ===
.vscode/
.idea/
.DS_Store
Thumbs.db

# === 기타 빌드 결과물 ===
**/target/